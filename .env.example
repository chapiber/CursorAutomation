# Cursor Cloud Agents API key — https://cursor.com/dashboard/integrations
CURSOR_API_KEY=cursor_xxxxxxxx

# Auth interne runner (header X-API-Key) — générer : openssl rand -hex 32
RUNNER_API_KEY=change_me_runner_key

# n8n encryption key — générer : openssl rand -hex 32
N8N_ENCRYPTION_KEY=change_me_n8n_encryption_key

# Chemins (dans le conteneur / sur NAS)
WORKSPACE_DIR=/workspaces
DEPLOY_DEST_PORTAIL_CLUB=/deploy/portailClub

# Repo GitHub cdm2026 (job cdm2026-daily)
CDM2026_REPO_URL=https://github.com/chapiber/cdm2026.git
CDM2026_BRANCH=main

# Timezone
TZ=Europe/Paris

# n8n — accès public HTTPS via reverse proxy DSM (port dédié, voir docs/DEPLOY-NAS.md)
N8N_EDITOR_BASE_URL=https://pevbenin2025.synology.me:5679
N8N_PROTOCOL=https
N8N_SECURE_COOKIE=true
N8N_TRUST_PROXY=true
N8N_PUSH_BACKEND=websocket
N8N_PROXY_HOPS=1
WEBHOOK_URL=https://pevbenin2025.synology.me:5679/
N8N_BLOCK_ENV_ACCESS_IN_NODE=false

# Auth : login owner n8n obligatoire (n8n 2.23)

# Maintenance OAuth en local : N8N_EDITOR_BASE_URL=http://localhost:5678,
# N8N_PROTOCOL=http, N8N_SECURE_COOKIE=false + tunnel SSH

N8N_HOST_PORT=5678
RUNNER_HOST_PORT=8765
N8N_UID=1026
N8N_GID=100