              "value": "={{ $('Journaliser phase').item.json.phase }}",
              "type": "string"
            },
            {
              "id": "msg-final",
              "name": "message",
              "value": "={{ $('Journaliser phase').item.json.message }}",
              "type": "string"
            },
            {
              "id": "report-text-ok",
              "name": "report_text",
              "value": "={{ $('Lire statut').item.json.report_text }}",
              "type": "string"
            },
            {
              "id": "cr-ok",
              "name": "cr",
              "value": "={{ $('Lire statut').item.json.report_text }}",
              "type": "string"
            }
          ]
        },
        "options": {}
      },
      "id": "set-ok",
      "name": "Résultat OK",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [1680, 180]
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "err",
              "name": "error",
              "value": "={{ $('Lire statut').item.json }}",
              "type": "object"
            },
            {
              "id": "phase-err",
              "name": "phase",
              "value": "={{ $('Journaliser phase').item.json.phase }}",
              "type": "string"
            },
            {
              "id": "msg-err",
              "name": "message",
              "value": "={{ $('Journaliser phase').item.json.message }}",
              "type": "string"
            },
            {
              "id": "report-text-err",
              "name": "report_text",
              "value": "={{ $('Lire statut').item.json.report_text }}",
              "type": "string"
            },
            {
              "id": "cr-err",
              "name": "cr",
              "value": "={{ $('Lire statut').item.json.report_text }}",
              "type": "string"
            }
          ]
        },
        "options": {}
      },
      "id": "set-err",
      "name": "Résultat erreur",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [1920, 420]
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "start-err",
              "name": "error",
              "value": "={{ $json }}",
              "type": "object"
            },
            {
              "id": "start-status",
              "name": "status",
              "value": "error",
              "type": "string"
            },
            {
              "id": "start-report",
              "name": "report_text",
              "value": "={{ 'CDM 2026 — erreur démarrage run\\n\\n' + JSON.stringify($json.error || $json, null, 2) }}",
              "type": "string"
            },
            {
              "id": "start-cr",
              "name": "cr",
              "value": "={{ 'CDM 2026 — erreur démarrage run\\n\\n' + JSON.stringify($json.error || $json, null, 2) }}",
              "type": "string"
            }
          ]
        },
        "options": {}
      },
      "id": "set-start-err",
      "name": "Erreur démarrage",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [920, 520]
    },
    {
      "parameters": {
        "resource": "message",
        "operation": "send",
        "sendTo": "chapron.loic@gmail.com",
        "subject": "={{ '[CDM 2026] ' + ($json.status || 'info') + ' — ' + $now.setZone('Europe/Paris').toFormat('dd/MM/yyyy HH:mm') }}",
        "emailType": "text",
        "message": "={{ $json.cr || $json.report_text || JSON.stringify($json, null, 2) }}",
        "options": {
          "appendAttribution": false
        }
      },
      "id": "gmail-notify",
      "name": "Envoyer CR par mail",
      "type": "n8n-nodes-base.gmail",
      "typeVersion": 2.1,
      "position": [2140, 300],
      "disabled": true,
      "credentials": {
        "gmailOAuth2": {
          "id": "GmailAccountCred",
          "name": "Gmail account"
        }
      }
    }
