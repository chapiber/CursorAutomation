# Cursor Cloud Agents API key — https://cursor.com/dashboard/integrations
CURSOR_API_KEY=cursor_xxxxxxxx

# Auth interne runner (header X-API-Key) — générer : openssl rand -hex 32
RUNNER_API_KEY=change_me_runner_key

# n8n encryption key — générer : openssl rand -hex 32
N8N_ENCRYPTION_KEY=change_me_n8n_encryption_key

# Chemins (dans le conteneur / sur NAS)
WORKSPACE_DIR=/workspaces
DEPLOY_DEST_PORTAIL_CLUB=/deploy/portailClub

# Repo GitHub MyDiveClub (pour git pull post-agent)
MYDIVECLUB_REPO_URL=https://github.com/chapiber/MyDiveClub.git
MYDIVECLUB_BRANCH=main

# Timezone
TZ=Europe/Paris

# n8n — LAN HTTP sans HTTPS (Synology)
N8N_SECURE_COOKIE=false

# Optionnel : port exposé runner pour tests LAN (0 = non exposé)
RUNNER_HOST_PORT=8765

# UID/GID pour n8n (Synology : id chapron = souvent 1026:100)
N8N_UID=1026
N8N_GID=100
