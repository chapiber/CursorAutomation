{
  "id": "CdM2026DailyWf01",
  "name": "CDM 2026 — MAJ toutes les 2h",
  "active": true,
  "activeVersionId": null,
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "cronExpression",
              "expression": "0 */2 * * *"
            }
          ]
        }
      },
      "id": "schedule-trigger",
      "name": "Toutes les 2h Paris",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [240, 300]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "loose"
          },
          "conditions": [
            {
              "id": "date-active",
              "leftValue": "={{ $now.setZone('Europe/Paris').toISODate() <= '2026-07-14' }}",
              "rightValue": "",
              "operator": {
                "type": "boolean",
                "operation": "true",
                "singleValue": true
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "if-active",
      "name": "Encore actif ?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [460, 300]
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "expired-status",
              "name": "status",
              "value": "expired",
              "type": "string"
            },
            {
              "id": "expired-report",
              "name": "report_text",
              "value": "CDM 2026 — workflow expiré (dernière exécution : 14/07/2026)",
              "type": "string"
            },
            {
              "id": "expired-cr",
              "name": "cr",
              "value": "CDM 2026 — workflow expiré (dernière exécution : 14/07/2026)",
              "type": "string"
            }
          ]
        },
        "options": {}
      },
      "id": "set-expired",
      "name": "Expiré",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [680, 480]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "http://skills-runner:8080/api/v1/runs",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "X-API-Key",
              "value": "={{ $env.RUNNER_API_KEY }}"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\"job_id\": \"cdm2026-daily\"}",
        "options": {}
      },
      "id": "http-start",
      "name": "Démarrer run",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [680, 300],
      "onError": "continueErrorOutput"
    },
    {
      "parameters": {
        "amount": 30,
        "unit": "seconds"
      },
      "id": "wait-30s",
      "name": "Attendre 30s",
      "type": "n8n-nodes-base.wait",
      "typeVersion": 1.1,
      "position": [920, 300],
      "webhookId": "cdm2026-wait-poll"
    },
    {
      "parameters": {
        "method": "GET",
        "url": "=http://skills-runner:8080/api/v1/runs/{{ $('Démarrer run').item.json.run_id }}",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "X-API-Key",
              "value": "={{ $env.RUNNER_API_KEY }}"
            }
          ]
        },
        "options": {}
      },
      "id": "http-poll",
      "name": "Lire statut",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1160, 300],
      "onError": "continueErrorOutput"
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "run-id",
              "name": "run_id",
              "value": "={{ $json.run_id }}",
              "type": "string"
            },
            {
              "id": "phase",
              "name": "phase",
              "value": "={{ $json.phase }}",
              "type": "string"
            },
            {
              "id": "message",
              "name": "message",
              "value": "={{ $json.message }}",
              "type": "string"
            },
            {
              "id": "status",
              "name": "status",
              "value": "={{ $json.status }}",
              "type": "string"
            },
            {
              "id": "elapsed",
              "name": "elapsed_sec",
              "value": "={{ $json.elapsed_sec }}",
              "type": "number"
            },
            {
              "id": "log-tail",
              "name": "log_tail",
              "value": "={{ ($json.log_tail || []).join(' | ') }}",
              "type": "string"
            },
            {
              "id": "report-text-journal",
              "name": "report_text",
              "value": "={{ $json.report_text }}",
              "type": "string"
            }
          ]
        },
        "options": {}
      },
      "id": "set-journal",
      "name": "Journaliser phase",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [1200, 300]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "status-done",
              "leftValue": "={{ $json.status }}",
              "rightValue": "done",
              "operator": {
                "type": "string",
                "operation": "equals"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "if-done",
      "name": "Terminé ?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [1440, 300]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "status-error",
              "leftValue": "={{ $json.status }}",
              "rightValue": "error",
              "operator": {
                "type": "string",
                "operation": "equals"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "if-error",
      "name": "Erreur ?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [1680, 420]
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "commit",
